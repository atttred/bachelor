<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Pipeline Funnel</title>
    <style>
        body { font-family: "Segoe UI", Arial, sans-serif; margin: 0; padding: 16px; background: #fff; color: #1f2937; }
        h3 { margin: 0 0 12px 0; font-size: 14px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; }
        svg { width: 100%; height: 280px; }
        .err { color: #b91c1c; font-size: 12px; }
        .row { stroke: #fff; stroke-width: 2; }
        .label { fill: #fff; font-size: 13px; font-weight: 600; }
        .count { fill: #fff; font-size: 12px; }
    </style>
</head>
<body>
    <h3>Pipeline by Sales Stage</h3>
    <svg id="funnel" viewBox="0 0 600 280" preserveAspectRatio="xMidYMid meet"></svg>
    <div id="err" class="err"></div>
    <script>
        var stages = [
            { value: 127550000, label: "Prospecting", color: "#0078d4" },
            { value: 127550001, label: "Qualified",   color: "#106ebe" },
            { value: 127550002, label: "Proposal",    color: "#005a9e" },
            { value: 127550003, label: "Negotiation", color: "#004578" },
            { value: 127550004, label: "Closing",     color: "#093565" }
        ];

        function render(counts) {
            var svg = document.getElementById("funnel");
            svg.innerHTML = "";
            var total = counts.reduce(function (a, b) { return a + b; }, 0) || 1;
            var rowHeight = 44;
            var maxWidth = 560;
            var x = 20, y = 20;
            for (var i = 0; i < stages.length; i++) {
                var w = Math.max(80, maxWidth * (counts[i] / total));
                var offsetX = (maxWidth - w) / 2 + x;
                var rect = document.createElementNS("http://www.w3.org/2000/svg", "rect");
                rect.setAttribute("x", offsetX);
                rect.setAttribute("y", y);
                rect.setAttribute("width", w);
                rect.setAttribute("height", rowHeight - 6);
                rect.setAttribute("fill", stages[i].color);
                rect.setAttribute("rx", "4");
                rect.setAttribute("class", "row");
                svg.appendChild(rect);

                var label = document.createElementNS("http://www.w3.org/2000/svg", "text");
                label.setAttribute("x", offsetX + 12);
                label.setAttribute("y", y + 24);
                label.setAttribute("class", "label");
                label.textContent = stages[i].label;
                svg.appendChild(label);

                var count = document.createElementNS("http://www.w3.org/2000/svg", "text");
                count.setAttribute("x", offsetX + w - 12);
                count.setAttribute("y", y + 24);
                count.setAttribute("text-anchor", "end");
                count.setAttribute("class", "count");
                count.textContent = counts[i];
                svg.appendChild(count);

                y += rowHeight;
            }
        }

        function load() {
            try {
                var xrm = window.parent && window.parent.Xrm;
                if (!xrm || !xrm.WebApi) {
                    document.getElementById("err").textContent = "Open from inside the app.";
                    render(stages.map(function () { return 0; }));
                    return;
                }
                var query = "?$select=vy_salesstagecode&$filter=statecode eq 0";
                xrm.WebApi.retrieveMultipleRecords("vy_opportunity", query).then(function (result) {
                    var counts = stages.map(function () { return 0; });
                    result.entities.forEach(function (e) {
                        var v = e.vy_salesstagecode;
                        for (var i = 0; i < stages.length; i++) {
                            if (stages[i].value === v) { counts[i]++; break; }
                        }
                    });
                    render(counts);
                }, function (err) {
                    document.getElementById("err").textContent = (err && err.message) || "Failed to load funnel data.";
                    render(stages.map(function () { return 0; }));
                });
            } catch (e) {
                document.getElementById("err").textContent = e.message || "Failed.";
            }
        }
        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", load);
        } else {
            load();
        }
    </script>
</body>
</html>
